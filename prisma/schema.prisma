generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  plan      String   @default("Free") // current active plan
  createdAt DateTime @default(now())
}

model Order {
  id        String    @id @default(cuid())
  reference String    @unique
  email     String
  plan      String
  cycle     String
  currency  String
  amount    Int // smallest unit (cents / paise)
  method    String
  status    String    @default("pending") // pending | paid | failed
  provider  String? // gateway order/invoice/link id
  paidAt    DateTime?
  createdAt DateTime  @default(now())
}
